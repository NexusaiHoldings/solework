{
  "lego_name": "profile-and-account",
  "version": "1.0.0",
  "description": "Typed event definitions for the profile-and-account lego (spec §7.6).",
  "events": [
    { "name": "profile.updated", "required": ["user_id"], "properties": { "user_id": "uuid", "completion_score": "integer" } },
    { "name": "account.connected_provider_added", "required": ["user_id", "provider"], "properties": { "user_id": "uuid", "provider": "string" } },
    { "name": "account.export_requested", "required": ["export_id", "user_id"], "properties": { "export_id": "uuid", "user_id": "uuid", "format": "string" } },
    { "name": "account.export_ready", "required": ["export_id"], "properties": { "export_id": "uuid", "download_url": "string" } }
  ]
}
